   "source": [
    "# GOREV 4 - Walking (4) icin ivme buyuklugu sqrt(x^2+y^2+z^2)  (once 0.5-20 Hz filtre)\n",
    "walk = df[df[\"activity_id\"] == 4]\n",
    "wx = bandpass_filter(walk[\"ankle_acc16_x\"].values)\n",
    "wy = bandpass_filter(walk[\"ankle_acc16_y\"].values)\n",
    "wz = bandpass_filter(walk[\"ankle_acc16_z\"].values)\n",
    "mag = acc_magnitude(wx, wy, wz)\n",
    "\n",
    "t = np.arange(len(mag)) / FS\n",
    "plt.figure(figsize=(12, 4))\n",
    "plt.plot(t, mag, lw=0.6)\n",
    "plt.xlabel(\"Zaman (s)\"); plt.ylabel(\"|ivme|  (m/s^2)\")\n",
    "plt.title(\"Walking - Ankle ivme buyuklugu (0.5-20 Hz filtreli)\")\n",
    "plt.tight_layout(); plt.show()\n",
    "print(\"Buyukluk sinyali uzunlugu:\", len(mag), \"ornek\")"
   ]
