   "source": [
    "## Aşama 2 — Tüm özneler, standing vs walking (Next Steps 1–8)\n",
    "\n",
    "Sıra: (1) tüm sinyali 0.5–20 Hz filtrele → (2) büyüklük → (3) standing/walking böl → (4) 4 sn pencere, %50 örtüşme → (5) öznitelik + subject_id + activity_id (0=standing, 1=walking) → ortak CSV."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "2702ea39",
   "metadata": {},
   "outputs": [],
   "source": [
    "# NEXT STEPS 1-5 - Ortak oznitelik tablosunu kur\n",
    "STANDING, WALKING = 3, 4\n",
    "ACT_LABEL = {STANDING: 0, WALKING: 1}   # 0=standing, 1=walking\n",
    "\n",
    "rows = []\n",
    "for sid in range(1, 10):\n",
    "    try:\n",
    "        d = load_subject(sid)\n",
    "    except FileNotFoundError:\n",
    "        print(f\"subject10{sid}.dat yok, atlandi.\"); continue\n",
    "    # (1) tum sinyali filtrele -> (2) buyukluk\n",
    "    x = bandpass_filter(d[\"ankle_acc16_x\"].values)\n",
    "    y = bandpass_filter(d[\"ankle_acc16_y\"].values)\n",
    "    z = bandpass_filter(d[\"ankle_acc16_z\"].values)\n",
    "    m = acc_magnitude(x, y, z)\n",
    "    aid = d[\"activity_id\"].values\n",
    "    # (3) bolgeler, (4) 4 sn %50 ortusen pencere, (5) oznitelik\n",
    "    for act in (STANDING, WALKING):\n",
    "        seg = m[aid == act]\n",
    "        if len(seg) < 4*FS:\n",
    "            continue\n",
    "        for w in segment_signal(seg, win_sec=4, fs=FS, overlap=0.5):\n",
    "            rows.append(extract_features(w) + [sid, ACT_LABEL[act]])\n",
    "\n",
    "table = pd.DataFrame(rows, columns=FEATURE_NAMES + [\"subject_id\", \"activity_id\"])\n",
    "print(\"Toplam pencere:\", len(table))\n",
    "print(\"Sinif dagilimi (0=standing, 1=walking):\")\n",
    "print(table[\"activity_id\"].value_counts().sort_index())\n",
    "print(\"\\nOzne basina pencere:\")\n",
    "print(table.groupby([\"subject_id\", \"activity_id\"]).size())\n",
    "table.head()"
   ]
  },
