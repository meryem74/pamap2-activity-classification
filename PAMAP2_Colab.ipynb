   "source": [
    "# 2) PAMAP2 veri setini indir ve ac (yalnizca daha once indirilmemisse)\n",
    "DATA_URL = \"https://archive.ics.uci.edu/static/public/231/pamap2+physical+activity+monitoring.zip\"\n",
    "\n",
    "dats = glob.glob(\"**/Protocol/subject*.dat\", recursive=True)\n",
    "if not dats:\n",
    "    print(\"Indiriliyor... (buyuk dosya, birkac dakika surebilir)\")\n",
    "    urllib.request.urlretrieve(DATA_URL, \"pamap2.zip\")\n",
    "    with zipfile.ZipFile(\"pamap2.zip\") as z:\n",
    "        z.extractall(\".\")\n",
    "    # UCI bazen ic ice ikinci bir zip koyar -> onu da ac\n",
    "    for inner in glob.glob(\"**/*.zip\", recursive=True):\n",
    "        if inner != \"pamap2.zip\":\n",
    "            try:\n",
    "                with zipfile.ZipFile(inner) as z:\n",
    "                    z.extractall(\".\")\n",
    "            except zipfile.BadZipFile:\n",
    "                pass\n",
    "    dats = glob.glob(\"**/Protocol/subject*.dat\", recursive=True)\n",
    "\n",
    "assert dats, \"subject*.dat bulunamadi - indirme/acma basarisiz.\"\n",
    "PROTOCOL = os.path.dirname(sorted(dats)[0])\n",
    "print(\"Protocol klasoru :\", PROTOCOL)\n",
    "print(\"Bulunan dosyalar :\", sorted(os.path.basename(d) for d in dats))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "97df0e2b",
   "metadata": {},
   "outputs": [],
   "source": [
    "# 3) Yardimci fonksiyonlar\n",
    "ACTIVITY_NAMES = {0:\"transient\",1:\"lying\",2:\"sitting\",3:\"standing\",4:\"walking\",\n",
    "                  5:\"running\",6:\"cycling\",7:\"nordic_walking\",9:\"watching_tv\",\n",
    "                  10:\"computer_work\",11:\"car_driving\",12:\"ascending_stairs\",\n",
    "                  13:\"descending_stairs\",16:\"vacuum_cleaning\",17:\"ironing\",\n",
    "                  18:\"folding_laundry\",19:\"house_cleaning\",20:\"playing_soccer\",\n",
    "                  24:\"rope_jumping\"}\n",
    "\n",
    "def get_column_names():\n",
    "    # Her IMU blogu 17 sutun: temp, acc16(x,y,z), acc6(x,y,z), gyro, mag, orient(4)\n",
    "    imu = [\"temp\",\"acc16_x\",\"acc16_y\",\"acc16_z\",\"acc6_x\",\"acc6_y\",\"acc6_z\",\n",
    "           \"gyro_x\",\"gyro_y\",\"gyro_z\",\"mag_x\",\"mag_y\",\"mag_z\",\n",
    "           \"orient_1\",\"orient_2\",\"orient_3\",\"orient_4\"]\n",
    "    cols = [\"timestamp\",\"activity_id\",\"heart_rate\"]\n",
    "    for loc in [\"hand\",\"chest\",\"ankle\"]:\n",
    "        cols += [f\"{loc}_{c}\" for c in imu]\n",
    "    return cols  # toplam 54 sutun\n",
    "\n",
    "def load_subject(sid):\n",
    "    path = os.path.join(PROTOCOL, f\"subject10{sid}.dat\")\n",
    "    return pd.read_csv(path, sep=r\"\\s+\", header=None, names=get_column_names())\n",
    "\n",
    "def bandpass_filter(signal, fs=FS, low=0.5, high=20.0, order=4):\n",
    "    # 0.5-20 Hz Butterworth bant-gecirgen (sifir fazli). NaN'lar interpolasyonla doldurulur.\n",
    "    sig = pd.Series(signal, dtype=\"float64\").interpolate(limit_direction=\"both\").to_numpy()\n",
    "    sig = np.nan_to_num(sig)\n",
    "    nyq = 0.5*fs\n",
    "    b, a = butter(order, [low/nyq, high/nyq], btype=\"bandpass\")\n",
    "    return filtfilt(b, a, sig)\n",
    "\n",
    "def acc_magnitude(x, y, z):\n",
    "    return np.sqrt(np.asarray(x)**2 + np.asarray(y)**2 + np.asarray(z)**2)\n",
    "\n",
    "def segment_signal(signal, win_sec=4, fs=FS, overlap=0.0):\n",
    "    # Her satir bir pencere. overlap=0.5 -> %50 ortusme.\n",
    "    signal = np.asarray(signal)\n",
    "    win = int(round(win_sec*fs))\n",
    "    step = max(1, int(round(win*(1-overlap))))\n",
    "    segs = [signal[s:s+win] for s in range(0, len(signal)-win+1, step)]\n",
    "    return np.array(segs) if segs else np.empty((0, win))\n",
    "\n",
    "FEATURE_NAMES = [\"energy\",\"shannon_entropy\",\"max_amplitude\",\"max_location\",\n",
    "                 \"min_amplitude\",\"min_location\"]\n",
    "\n",
    "def shannon_entropy(window, bins=32):\n",
    "    hist, _ = np.histogram(window, bins=bins)\n",
    "    p = hist.astype(float); p = p[p > 0]\n",
    "    if p.size == 0:\n",
    "        return 0.0\n",
    "    p /= p.sum()\n",
    "    return float(-np.sum(p*np.log2(p)))\n",
    "\n",
    "def extract_features(window):\n",
    "    w = np.asarray(window, dtype=\"float64\")\n",
    "    return [float(np.sum(w**2)),          # energy\n",
    "            shannon_entropy(w),           # Shannon entropy\n",
    "            float(np.max(w)), int(np.argmax(w)),   # max amplitude + location\n",
    "            float(np.min(w)), int(np.argmin(w))]   # min amplitude + location\n",
    "\n",
    "ANKLE_ACC = [\"ankle_acc16_x\",\"ankle_acc16_y\",\"ankle_acc16_z\"]\n",
    "print(\"Yardimci fonksiyonlar hazir. Sutun sayisi:\", len(get_column_names()))"
   ]
  },
