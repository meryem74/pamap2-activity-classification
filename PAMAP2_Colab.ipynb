   "source": [
    "# 1) Kurulum ve importlar (Colab'da xgboost genelde yuklu; degilse alttaki satiri acin)\n",
    "# !pip install xgboost -q\n",
    "import os, glob, zipfile, urllib.request\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "from scipy.signal import butter, filtfilt\n",
    "from scipy.stats import mannwhitneyu\n",
    "from sklearn.base import clone\n",
    "from sklearn.preprocessing import StandardScaler\n",
    "from sklearn.pipeline import Pipeline\n",
    "from sklearn.model_selection import train_test_split, LeaveOneGroupOut\n",
    "from sklearn.svm import SVC\n",
    "from sklearn.ensemble import RandomForestClassifier\n",
    "from sklearn.linear_model import LogisticRegression\n",
    "from sklearn.metrics import accuracy_score, recall_score, precision_score, f1_score\n",
    "\n",
    "try:\n",
    "    from xgboost import XGBClassifier\n",
    "    HAS_XGB = True\n",
    "except Exception:\n",
    "    HAS_XGB = False\n",
    "    print(\"xgboost bulunamadi; XGBoost atlanacak. Kurmak icin yeni hucrede:  !pip install xgboost\")\n",
    "\n",
    "FS = 100  # PAMAP2 ornekleme hizi (Hz)\n",
    "print(\"Hazir. Ornekleme hizi:\", FS, \"Hz | XGBoost:\", HAS_XGB)"
   ]
  },
  {
