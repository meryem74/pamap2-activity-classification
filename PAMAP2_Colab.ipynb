   "source": [
    "# GOREV 3 - Ankle ivme X/Y/Z'yi 0.5-20 Hz filtrele, spektrum + baskin frekans\n",
    "fig, axs = plt.subplots(3, 1, figsize=(10, 9), sharex=True)\n",
    "for i, col in enumerate(ANKLE_ACC):\n",
    "    filt = bandpass_filter(df[col].values)\n",
    "    N = len(filt)\n",
    "    freqs = np.fft.rfftfreq(N, d=1/FS)\n",
    "    spec = np.abs(np.fft.rfft(filt)) / N\n",
    "    dom = freqs[1:][np.argmax(spec[1:])]   # DC haric en buyuk tepe = baskin frekans\n",
    "    print(f\"{col}: baskin frekans = {dom:.2f} Hz\")\n",
    "    axs[i].plot(freqs, spec, lw=0.8)\n",
    "    axs[i].axvline(dom, color=\"r\", ls=\"--\", label=f\"baskin = {dom:.2f} Hz\")\n",
    "    axs[i].set_xlim(0, 25)\n",
    "    axs[i].set_ylabel(\"|X(f)|\"); axs[i].set_title(col); axs[i].legend(loc=\"upper right\")\n",
    "axs[-1].set_xlabel(\"Frekans (Hz)\")\n",
    "plt.tight_layout(); plt.show()"
   ]
