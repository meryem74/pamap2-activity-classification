   "outputs": [],
   "source": [
    "# NEXT STEPS 6 - Mann-Whitney U testi (standing vs walking, oznitelik bazinda)\n",
    "st = table[table[\"activity_id\"] == 0]\n",
    "wk = table[table[\"activity_id\"] == 1]\n",
    "print(f\"{'oznitelik':<16}{'U':>14}{'p-degeri':>14}   anlamli?\")\n",
    "for f in FEATURE_NAMES:\n",
    "    u, p = mannwhitneyu(st[f], wk[f], alternative=\"two-sided\")\n",
    "    print(f\"{f:<16}{u:>14.1f}{p:>14.3e}   {'EVET' if p < 0.05 else 'hayir'}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "0bd9247f",
   "metadata": {},
   "outputs": [],
   "source": [
    "# NEXT STEPS 7 - Modeller + 80/20 bolme\n",
    "def get_models():\n",
    "    m = {\n",
    "        \"SVM\": Pipeline([(\"sc\", StandardScaler()), (\"clf\", SVC(kernel=\"rbf\", C=1.0))]),\n",
    "        \"RandomForest\": RandomForestClassifier(n_estimators=200, random_state=42),\n",
    "        \"LogisticRegression\": Pipeline([(\"sc\", StandardScaler()),\n",
    "                                        (\"clf\", LogisticRegression(max_iter=1000))]),\n",
    "    }\n",
    "    if HAS_XGB:\n",
    "        m[\"XGBoost\"] = XGBClassifier(n_estimators=200, max_depth=4, learning_rate=0.1,\n",
    "                                     eval_metric=\"logloss\", random_state=42)\n",
    "    return m\n",
    "\n",
    "def metrics(yt, yp):\n",
    "    return (accuracy_score(yt, yp),\n",
    "            recall_score(yt, yp, zero_division=0),     # sensitivity\n",
    "            precision_score(yt, yp, zero_division=0),\n",
    "            f1_score(yt, yp, zero_division=0))\n",
    "\n",
    "X = table[FEATURE_NAMES].values\n",
    "y = table[\"activity_id\"].values\n",
    "Xtr, Xte, ytr, yte = train_test_split(X, y, test_size=0.2, stratify=y, random_state=42)\n",
    "\n",
    "print(\"Siniflandirma - 80/20 bolme (stratify)\")\n",
    "print(f\"{'model':<20}{'acc':>8}{'recall':>9}{'prec':>9}{'f1':>9}\")\n",
    "for name, model in get_models().items():\n",
    "    mdl = clone(model); mdl.fit(Xtr, ytr)\n",
    "    a, r, p, f = metrics(yte, mdl.predict(Xte))\n",
    "    print(f\"{name:<20}{a:>8.3f}{r:>9.3f}{p:>9.3f}{f:>9.3f}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "1b48803f",
   "metadata": {},
   "outputs": [],
   "source": [
    "# NEXT STEPS 7-8 - LOSO-CV (subject_id yalnizca grup; oznitelik/label DEGIL)\n",
    "groups = table[\"subject_id\"].values\n",
    "logo = LeaveOneGroupOut()\n",
    "\n",
    "print(\"Siniflandirma - LOSO-CV (ozne basina ortalama)\")\n",
    "print(f\"{'model':<20}{'acc':>8}{'recall':>9}{'prec':>9}{'f1':>9}\")\n",
    "for name, model in get_models().items():\n",
    "    A, R, P, F = [], [], [], []\n",
    "    for tr, te in logo.split(X, y, groups):\n",
    "        mdl = clone(model); mdl.fit(X[tr], y[tr])\n",
    "        a, r, p, f = metrics(y[te], mdl.predict(X[te]))\n",
    "        A.append(a); R.append(r); P.append(p); F.append(f)\n",
    "    print(f\"{name:<20}{np.mean(A):>8.3f}{np.mean(R):>9.3f}{np.mean(P):>9.3f}{np.mean(F):>9.3f}\")"
   ]
  }
